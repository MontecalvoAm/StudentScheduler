generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────
// MASTER: ROLES & USERS
// ─────────────────────────────────────────

model M_Role {
  RoleId      Int     @id @default(autoincrement())
  RoleToken   String  @unique @default(uuid()) @db.VarChar(36)
  RoleName    String  @unique @db.VarChar(50)
  Description String? @db.VarChar(255)
  IsSystem    Boolean @default(false) // true = seeded system roles (SUPER_ADMIN, etc.)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Users       M_User[]
  Permissions M_RolePermission[]

  @@map("M_Role")
}

model M_User {
  UserId            Int       @id @default(autoincrement())
  UserToken         String    @unique @default(uuid()) @db.VarChar(36)
  RoleId            Int
  Email             String    @unique @db.VarChar(255)
  PasswordHash      String    @db.VarChar(255)
  FirstName         String    @db.VarChar(100)
  LastName          String    @db.VarChar(100)
  MiddleName        String?   @db.VarChar(100)
  IsActive          Boolean   @default(true)
  IsLocked          Boolean   @default(false)
  FailedLoginCount  Int       @default(0)
  LockedUntil       DateTime?
  LastLoginAt       DateTime?
  PasswordChangedAt DateTime?
  MfaSecret         String?   @db.VarChar(255) // TOTP scaffold — not enforced Phase 1
  MfaEnabled        Boolean   @default(false)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime? // soft delete

  Role          M_Role                     @relation(fields: [RoleId], references: [RoleId])
  Student       M_Student?
  Instructor    M_Instructor?
  RefreshTokens T_RefreshToken[]
  AuditLogs     T_AuditLog[]
  Overrides     M_UserPermissionOverride[]

  @@index([RoleId])
  @@index([Email])
  @@index([DeletedAt])
  @@map("M_User")
}

// ─────────────────────────────────────────
// TRANSACTIONAL: REFRESH TOKENS
// ─────────────────────────────────────────

model T_RefreshToken {
  TokenId   Int      @id @default(autoincrement())
  UserId    Int
  TokenHash String   @unique @db.VarChar(512)
  ExpiresAt DateTime
  IsRevoked Boolean  @default(false)
  IpAddress String?  @db.VarChar(45)
  UserAgent String?  @db.VarChar(500)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime?
  DeletedBy Int?
  DeletedAt DateTime?

  User M_User @relation(fields: [UserId], references: [UserId])

  @@index([UserId])
  @@index([ExpiresAt])
  @@map("T_RefreshToken")
}

// ─────────────────────────────────────────
// MASTER: PROFILES
// ─────────────────────────────────────────

model M_Student {
  StudentId     Int     @id @default(autoincrement())
  UserId        Int     @unique
  StudentNumber String  @unique @db.VarChar(50)
  CourseId      Int?
  YearLevel     Int?
  Section       String? @db.VarChar(20)
  StudySession  String? @db.VarChar(10) // Day/Night session

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  User              M_User               @relation(fields: [UserId], references: [UserId])
  Course            M_Course?            @relation(fields: [CourseId], references: [CourseId])
  Enrollments       MT_Enrollment[]
  AttendanceRecords T_AttendanceRecord[]
  StudyPlan         T_StudentStudyPlan?

  @@index([CourseId])
  @@index([StudentNumber])
  @@map("M_Student")
}

model M_Instructor {
  InstructorId   Int     @id @default(autoincrement())
  UserId         Int     @unique
  EmployeeNumber String  @unique @db.VarChar(50)
  DepartmentId   Int?
  Specialization String? @db.VarChar(100)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  User             M_User               @relation(fields: [UserId], references: [UserId])
  Department       M_Department?        @relation(fields: [DepartmentId], references: [DepartmentId])
  ClassAssignments MT_ClassAssignment[]

  @@index([DepartmentId])
  @@map("M_Instructor")
}

// ─────────────────────────────────────────
// MASTER: ACADEMIC STRUCTURE
// ─────────────────────────────────────────

model M_Department {
  DepartmentId    Int     @id @default(autoincrement())
  DepartmentToken String  @unique @default(uuid()) @db.VarChar(36)
  DepartmentCode  String  @unique @db.VarChar(20)
  DepartmentName  String  @db.VarChar(200)
  Description     String? @db.Text
  IsActive        Boolean @default(true)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Courses     M_Course[]
  Instructors M_Instructor[]

  @@map("M_Department")
}

model M_Course {
  CourseId      Int     @id @default(autoincrement())
  CourseToken   String  @unique @default(uuid()) @db.VarChar(36)
  DepartmentId  Int?
  CourseCode    String  @unique @db.VarChar(20)
  CourseName    String  @db.VarChar(200)
  Description   String? @db.Text
  YearsDuration Int     @default(4)
  RequiredUnits Int     @default(120)
  IsActive      Boolean @default(true)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Department     M_Department?     @relation(fields: [DepartmentId], references: [DepartmentId])
  Students       M_Student[]
  Subjects       M_Subject[]
  CourseSubjects M_CourseSubject[]

  @@index([DepartmentId])
  @@map("M_Course")
}

model M_Subject {
  SubjectId    Int     @id @default(autoincrement())
  SubjectToken String  @unique @default(uuid()) @db.VarChar(36)
  CourseId     Int?
  SubjectCode  String  @unique @db.VarChar(20)
  SubjectName  String  @db.VarChar(200)
  Units        Int     @default(3)
  Description  String? @db.Text
  IsActive     Boolean @default(true)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Course                   M_Course?                   @relation(fields: [CourseId], references: [CourseId])
  Classes                  MT_Class[]
  CourseSubjects           M_CourseSubject[]
  PrerequisitesOf          M_SubjectPrerequisite[]     @relation("MainSubject")
  PrerequisitesRequired    M_SubjectPrerequisite[]     @relation("PrereqSubject")
  StudentStudyPlanSubjects T_StudentStudyPlanSubject[]

  @@index([CourseId])
  @@map("M_Subject")
}

model M_Room {
  RoomId   Int     @id @default(autoincrement())
  RoomCode String  @unique @db.VarChar(30)
  RoomName String  @db.VarChar(100)
  Building String? @db.VarChar(100)
  Capacity Int     @default(40)
  IsActive Boolean @default(true)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Schedules MT_Schedule[]

  @@map("M_Room")
}

// ─────────────────────────────────────────
// MASTER: ACADEMIC TERMS
// ─────────────────────────────────────────

model M_SchoolYear {
  SchoolYearId Int      @id @default(autoincrement())
  YearLabel    String   @unique @db.VarChar(20) // e.g. "2025-2026"
  StartDate    DateTime @db.Date
  EndDate      DateTime @db.Date
  IsActive     Boolean  @default(false)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Semesters M_Semester[]

  @@map("M_SchoolYear")
}

model M_Semester {
  SemesterId   Int      @id @default(autoincrement())
  SchoolYearId Int
  SemesterName String   @db.VarChar(50) // "First Semester" | "Second Semester" | "Summer"
  StartDate    DateTime @db.Date
  EndDate      DateTime @db.Date
  IsActive     Boolean  @default(false)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  SchoolYear M_SchoolYear @relation(fields: [SchoolYearId], references: [SchoolYearId])
  Classes    MT_Class[]

  @@index([SchoolYearId])
  @@map("M_Semester")
}

// ─────────────────────────────────────────
// MASTER-TRANSACTIONAL: CLASSES & SCHEDULES
// ─────────────────────────────────────────

model MT_Class {
  ClassId      Int     @id @default(autoincrement())
  SubjectId    Int
  SemesterId   Int
  SectionCode  String  @db.VarChar(30)
  StudySession String? @db.VarChar(10) // Day/Night session
  MaxStudents  Int     @default(40)
  IsActive     Boolean @default(true)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Subject          M_Subject            @relation(fields: [SubjectId], references: [SubjectId])
  Semester         M_Semester           @relation(fields: [SemesterId], references: [SemesterId])
  Schedules        MT_Schedule[]
  Enrollments      MT_Enrollment[]
  ClassAssignments MT_ClassAssignment[]

  @@unique([SubjectId, SectionCode, SemesterId])
  @@index([SemesterId])
  @@index([SubjectId])
  @@map("MT_Class")
}

model MT_Schedule {
  ScheduleId    Int       @id @default(autoincrement())
  ClassId       Int
  RoomId        Int
  DayOfWeek     Int // 0=Sunday … 6=Saturday
  StartTime     String    @db.VarChar(5) // "08:00" HH:MM 24h
  EndTime       String    @db.VarChar(5) // "09:30" HH:MM 24h
  EffectiveFrom DateTime  @db.Date
  EffectiveTo   DateTime? @db.Date
  IsActive      Boolean   @default(true)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Class              MT_Class              @relation(fields: [ClassId], references: [ClassId])
  Room               M_Room                @relation(fields: [RoomId], references: [RoomId])
  AttendanceSessions T_AttendanceSession[]

  @@index([ClassId, DayOfWeek])
  @@index([RoomId, DayOfWeek])
  @@map("MT_Schedule")
}

model MT_Enrollment {
  EnrollmentId Int       @id @default(autoincrement())
  StudentId    Int
  ClassId      Int
  EnrolledAt   DateTime  @default(now())
  DroppedAt    DateTime?
  Status       String    @default("ACTIVE") @db.VarChar(20) // ACTIVE | DROPPED | COMPLETED

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime?
  DeletedBy Int?
  DeletedAt DateTime?

  Student M_Student @relation(fields: [StudentId], references: [StudentId])
  Class   MT_Class  @relation(fields: [ClassId], references: [ClassId])

  @@unique([StudentId, ClassId])
  @@index([ClassId])
  @@index([StudentId])
  @@map("MT_Enrollment")
}

model MT_ClassAssignment {
  AssignmentId Int       @id @default(autoincrement())
  InstructorId Int
  ClassId      Int
  AssignedAt   DateTime  @default(now())
  RemovedAt    DateTime?
  IsPrimary    Boolean   @default(true)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime?
  DeletedBy Int?
  DeletedAt DateTime?

  Instructor M_Instructor @relation(fields: [InstructorId], references: [InstructorId])
  Class      MT_Class     @relation(fields: [ClassId], references: [ClassId])

  @@unique([InstructorId, ClassId])
  @@index([ClassId])
  @@map("MT_ClassAssignment")
}

// ─────────────────────────────────────────
// TRANSACTIONAL: ATTENDANCE
// ─────────────────────────────────────────

model T_AttendanceSession {
  SessionId   Int       @id @default(autoincrement())
  ScheduleId  Int
  SessionDate DateTime  @db.Date
  OpenedAt    DateTime?
  ClosedAt    DateTime?
  AutoCloseAt DateTime?
  QrCodeToken String?   @unique @db.VarChar(512) // signed JWT token
  QrExpiresAt DateTime?
  Status      String    @default("PENDING") @db.VarChar(20) // PENDING | OPEN | CLOSED | CANCELLED
  Method      String    @default("BUTTON") @db.VarChar(20) // BUTTON | QR | BOTH

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Schedule          MT_Schedule          @relation(fields: [ScheduleId], references: [ScheduleId])
  AttendanceRecords T_AttendanceRecord[]

  @@index([ScheduleId, SessionDate])
  @@index([Status])
  @@map("T_AttendanceSession")
}

model T_AttendanceRecord {
  AttendanceRecordId Int       @id @default(autoincrement())
  SessionId          Int
  StudentId          Int
  Status             String    @db.VarChar(20) // PRESENT | LATE | ABSENT | EXCUSED
  MarkedAt           DateTime  @default(now())
  MarkedByUserId     Int?
  Remarks            String?   @db.Text
  IsOverridden       Boolean   @default(false)
  OverriddenAt       DateTime?
  OverriddenByUserId Int?

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Session T_AttendanceSession @relation(fields: [SessionId], references: [SessionId])
  Student M_Student           @relation(fields: [StudentId], references: [StudentId])

  @@unique([SessionId, StudentId]) // immutable: one record per student per session
  @@index([StudentId])
  @@index([SessionId])
  @@map("T_AttendanceRecord")
}

// ─────────────────────────────────────────
// TRANSACTIONAL: AUDIT & SYSTEM
// ─────────────────────────────────────────

model T_AuditLog {
  AuditLogId Int     @id @default(autoincrement())
  UserId     Int?
  Action     String  @db.VarChar(100) // e.g. USER_CREATED, ATTENDANCE_OVERRIDDEN
  EntityType String  @db.VarChar(100) // e.g. M_User, T_AttendanceRecord
  EntityId   String? @db.VarChar(50)
  OldValues  Json?
  NewValues  Json?
  IpAddress  String? @db.VarChar(45)
  UserAgent  String? @db.VarChar(500)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime?
  DeletedBy Int?
  DeletedAt DateTime?

  User M_User? @relation(fields: [UserId], references: [UserId])

  @@index([UserId])
  @@index([EntityType, EntityId])
  @@index([CreatedAt])
  @@index([Action])
  @@map("T_AuditLog")
}

// ─────────────────────────────────────────
// MASTER: SYSTEM SETTINGS
// ─────────────────────────────────────────

model M_SystemSetting {
  SettingId       Int     @id @default(autoincrement())
  SettingKey      String  @unique @db.VarChar(100)
  SettingValue    String  @db.Text
  Description     String? @db.VarChar(255)
  UpdatedByUserId Int?

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  @@map("M_SystemSetting")
}

// New Subject Prerequisite table
model M_SubjectPrerequisite {
  PrerequisiteId        Int    @id @default(autoincrement())
  PrerequisiteToken     String @unique @default(uuid()) @db.VarChar(36)
  SubjectId             Int
  PrerequisiteSubjectId Int

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Subject             M_Subject @relation("MainSubject", fields: [SubjectId], references: [SubjectId])
  PrerequisiteSubject M_Subject @relation("PrereqSubject", fields: [PrerequisiteSubjectId], references: [SubjectId])

  @@unique([SubjectId, PrerequisiteSubjectId])
  @@map("M_SubjectPrerequisite")
}

// New Course Subject Mapping table (Curriculum)
model M_CourseSubject {
  CourseSubjectId    Int    @id @default(autoincrement())
  CourseSubjectToken String @unique @default(uuid()) @db.VarChar(36)
  CourseId           Int
  SubjectId          Int
  YearLevel          Int // 1, 2, 3, 4, etc.
  Semester           Int // 1 = 1st, 2 = 2nd, 3 = Summer

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Course  M_Course  @relation(fields: [CourseId], references: [CourseId])
  Subject M_Subject @relation(fields: [SubjectId], references: [SubjectId])

  @@unique([CourseId, SubjectId, YearLevel, Semester])
  @@map("M_CourseSubject")
}

// New Custom Study Plan for Irregular Students
model T_StudentStudyPlan {
  StudyPlanId    Int    @id @default(autoincrement())
  StudyPlanToken String @unique @default(uuid()) @db.VarChar(36)
  StudentId      Int    @unique

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Student  M_Student                   @relation(fields: [StudentId], references: [StudentId])
  Subjects T_StudentStudyPlanSubject[]

  @@map("T_StudentStudyPlan")
}

model T_StudentStudyPlanSubject {
  StudyPlanSubjectId    Int    @id @default(autoincrement())
  StudyPlanSubjectToken String @unique @default(uuid()) @db.VarChar(36)
  StudyPlanId           Int
  SubjectId             Int
  TargetYearLevel       Int
  TargetSemester        Int
  Status                String @default("PENDING") @db.VarChar(20) // PENDING | ENROLLED | COMPLETED | FAILED

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  StudyPlan T_StudentStudyPlan @relation(fields: [StudyPlanId], references: [StudyPlanId])
  Subject   M_Subject          @relation(fields: [SubjectId], references: [SubjectId])

  @@unique([StudyPlanId, SubjectId])
  @@map("T_StudentStudyPlanSubject")
}

// ─────────────────────────────────────────
// MASTER: RBAC — MODULES & PERMISSIONS
// ─────────────────────────────────────────

model M_Module {
  ModuleId    Int     @id @default(autoincrement())
  ModuleKey   String  @unique @db.VarChar(50) // e.g. "users", "schedules"
  ModuleLabel String  @db.VarChar(100) // e.g. "Users Management"
  SortOrder   Int     @default(0)
  IsActive    Boolean @default(true)

  Permissions M_RolePermission[]
  Overrides   M_UserPermissionOverride[]

  @@map("M_Module")
}

model M_RolePermission {
  PermissionId    Int     @id @default(autoincrement())
  PermissionToken String  @unique @default(uuid()) @db.VarChar(36)
  RoleId          Int
  ModuleId        Int
  CanCreate       Boolean @default(false)
  CanRead         Boolean @default(false)
  CanUpdate       Boolean @default(false)
  CanDelete       Boolean @default(false)

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  Role   M_Role   @relation(fields: [RoleId], references: [RoleId])
  Module M_Module @relation(fields: [ModuleId], references: [ModuleId])

  @@unique([RoleId, ModuleId])
  @@index([RoleId])
  @@map("M_RolePermission")
}

model M_UserPermissionOverride {
  OverrideId    Int      @id @default(autoincrement())
  OverrideToken String   @unique @default(uuid()) @db.VarChar(36)
  UserId        Int
  ModuleId      Int
  CanCreate     Boolean?
  CanRead       Boolean?
  CanUpdate     Boolean?
  CanDelete     Boolean?

  // Audit Columns
  CreatedBy Int?
  CreatedAt DateTime  @default(now())
  UpdatedBy Int?
  UpdatedAt DateTime  @updatedAt
  DeletedBy Int?
  DeletedAt DateTime?

  User   M_User   @relation(fields: [UserId], references: [UserId])
  Module M_Module @relation(fields: [ModuleId], references: [ModuleId])

  @@unique([UserId, ModuleId])
  @@index([UserId])
  @@map("M_UserPermissionOverride")
}
